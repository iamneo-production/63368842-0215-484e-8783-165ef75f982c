nst active = false;\r\n\r\nconst handleClick=(e)=>{\r\ne.preventDefault()\r\nconst user={email, password}\r\nconsole.log(user);\r\nfetch(\"http://localhost:8080/user/login\",\r\n{\r\nmethod:\"POST\",\r\nheaders:{\"Content-Type\":\"application/json\"},\r\nbody:JSON.stringify(user)\r\n}).then(response=>response.json().then(res=>setActiveChecker(res)))\r\nlocalStorage.setItem('to',email);\r\n}\r\n\r\nconsole.log(activechecker);\r\nif(!activechecker){\r\n    return(\r\n    <div className=\"bg\">\r\n    <br></br>\r\n    <br></br>\r\n     <div  className=\"titlebar\"> \r\n        Login\r\n    </div>\r\n    <div  className=\"form\">\r\n        <br></br>\r\n        <br></br>\r\n        <form>\r\n            <input placeholder = \"Email\" type = \"text\" id = \"email\" name='email' value={email} onChange={(e)=>setEmail(e.target.value)}></input>\r\n            <br></br>\r\n            <input placeholder = \"Password\" type = \"text\" id =  \"password\" name = \"password\" value={password} onChange={(e)=>setPassword(e.target.value)}></input>\r\n            <br></br>\r\n        </form>\r\n        <div className=\"center\">\r\n        <button  id = \"submitButton\" type='submit' value=\"Submit\" onClick={handleClick}> Submit </button>\r\n        <br></br>\r\n        </div>\r\n        <br></br>\r\n    </div>\r\n    <p >Not a Member? <Link to = \"/\" className=\"link\"> Signup</Link></p>\r\n    <br></br>\r\n    </div>\r\n     \r\n);}else{\r\n    return(<Navigate to=\"/home\" replace={true} />);\r\n}\r\n}\r\n",["120","121"],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\EditTheme.jsx",["122","123","124","125","126","127","128","129","130","131"],[],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\orders.jsx",["132","133","134","135","136","137","138","139","140","141","142"],[],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\AdminTheme.jsx",["143","144","145","146","147","148","149","150","151"],[],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\Signup.jsx",["152","153","154","155","156"],[],"import React, { useState } from \"react\";\r\nimport {Link,Routes, Route, Navigate, BrowserRouter} from 'react-router-dom';\r\nimport Login from \"./Login\";\r\nimport './Design.css';\r\ndocument.body.style.overflow = \"hidden\"\r\n\r\nfunction Signup(){\r\n\r\nconst getInitialState = () => {\r\n    const usertype = \"user\";\r\n    return usertype;\r\n  };\r\nconst [usertype, setUserType] = useState(getInitialState);\r\nconst[email,setEmail]=useState('');\r\nconst[username,setUsername]=useState('');\r\nconst[mobile,setMobile]=useState('');\r\nconst[password,setPassword]=useState('');\r\nconst[repassword,setRePassword]=useState('');\r\n\r\nconst options = [{label: \"Admin\",value: \"admin\",},{label: \"User\",value: \"user\",}];\r\n\r\n\r\nconst active = false;\r\n\r\n\r\nconst handleClick=(e)=>{\r\ne.preventDefault()\r\nconst user={usertype,email,username, mobile, password, repassword,active}\r\nconsole.log(user)\r\nfetch(\"http://localhost:8080/user/signup\",\r\n{\r\nmethod:\"POST\",\r\nheaders:{\"Content-Type\":\"application/json\"},\r\nbody:JSON.stringify(user)\r\n}).then(()=>{alert(\"Registration Completed\")})\r\n}\r\n\r\n\r\n\r\n    return (\r\n    <>  \r\n<div className=\"bg1\">\r\n<br></br>\r\n<br></br>\r\n<div className=\"titlebar\">\r\n        Register\r\n    </div>\r\n\r\n    <div className=\"form\">\r\n        <form >\r\n        <br></br>\r\n        \r\n            <select value={usertype} onChange={(e)=>setUserType(e.target.value)}>\r\n            {options.map((option) => (\r\n              <option value={option.value}>{option.label}</option>\r\n            ))}\r\n            </select>\r\n            <br></br>\r\n            <input placeholder = \"Email\" type = \"email\" id = \"email\" name='email' value={email} onChange={(e)=>setEmail(e.target.value)}></input>\r\n            <br></br>\r\n            <input placeholder = \"Username\" type = \"text\" id =  \"username\" name = \"username\" value={username} onChange={(e)=>setUsername(e.target.value)}></input>\r\n            <br></br>\r\n            <input placeholder = \"Mobile Number\" type = \"text\" id =  \"mobileNumber\" name = \"mobileNumber\" value={mobile} onChange={(e)=>setMobile(e.target.value)}></input>\r\n            <br></br>\r\n            <input placeholder = \"Password\" type = \"text\" id =  \"password\" name = \"password\" value={password} onChange={(e)=>setPassword(e.target.value)}></input>\r\n            <br></br>\r\n            <input placeholder = \"Confirm Password\" type = \"text\" id =  \"confirmpassword\" name = \"confirmpassowrd\" value={repassword} onChange={(e)=>setRePassword(e.target.value)}></input>\r\n        </form>\r\n        <div className=\"center\">\r\n        <button id = \"submitButton\" type='submit' value=\"Submit\" onClick={handleClick}> Submit </button>\r\n        </div>\r\n        <br></br>\r\n    </div>\r\n    <p >Already an User?  < Link to = \"/user/login\" className=\"link\"> Login</Link> </p>\r\n    <p >Already an Admin?  < Link to = \"/admin/login\" className=\"link\"> Admin Login</Link> </p>\r\n    <br></br>\r\n</div>\r\n    </>)\r\n}\r\n\r\n\r\n\r\nexport default Signup;\r\n","C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\AdminLogin.jsx",["157","158","159","160","161","162"],[],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\Homepage.jsx",["163","164","165","166","167","168","169","170","171"],[],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\Cart.jsx",["172","173","174","175","176","177","178","179","180","181","182","183"],[],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\UserOrders.jsx",["184","185","186","187","188","189","190","191","192"],[],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\EditCart.jsx",["193","194","195","196","197","198","199","200","201","202","203","204","205","206","207","208","209"],[],"C:\\Users\\vtu13\\VIVEK\\Project\\frontend\\src\\Orders.jsx",["210","211","212","213","214","215","216","217","218","219"],[],{"ruleId":"220","severity":1,"message":"221",